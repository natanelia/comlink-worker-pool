{
  "name": "comlink-worker-pool",
  "version": "0.0.3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/natanelia/comlink-worker-pool.git"
  },
  "scripts": {
    "playground:lint": "bun run -F comlink-worker-pool-playground lint",
    "playground:typecheck": "bun run -F comlink-worker-pool-playground typecheck",
    "playground:build": "bun run -F comlink-worker-pool-playground build",
    "playground:dev": "bun run -F comlink-worker-pool-playground dev",
    "lint": "bun run -F comlink-worker-pool-react -F comlink-worker-pool -F comlink-worker-pool-playground lint",
    "typecheck": "bun run -F comlink-worker-pool-react -F comlink-worker-pool -F comlink-worker-pool-playground typecheck",
    "build": "bun run -F comlink-worker-pool-react -F comlink-worker-pool build",
    "build:watch": "bun run -F comlink-worker-pool-react -F comlink-worker-pool build",
    "test": "bun run -F comlink-worker-pool-react -F comlink-worker-pool test",
    "test:exports": "node scripts/smoke-package-exports.cjs",
    "verify": "bun run lint && bun run typecheck && bun run test && bun run build && bun run playground:build && bun run test:exports",
    "changeset": "changeset",
    "version": "changeset version && bun install",
    "release": "bun run build && bun run test && changeset publish"
  },
  "private": true,
  "workspaces": [
    "packages/comlink-worker-pool",
    "packages/playground",
    "packages/comlink-worker-pool-react"
  ],
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@changesets/cli": "^2.29.2"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}

{
	"name": "comlink-worker-pool-react",
	"version": "0.0.9",
	"description": "React hooks for comlink-worker-pool. Seamlessly integrate web worker pools into React apps with the useWorkerPool hook",
	"author": "Natan Elia",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/natanelia/comlink-worker-pool.git"
	},
	"type": "module",
	"main": "./dist/index.cjs",
	"types": "./dist/index.d.ts",
	"module": "./dist/index.js",
	"files": ["dist"],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"sideEffects": false,
	"scripts": {
		"build": "bunup",
		"test": "bun test",
		"lint": "biome check .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"comlink-worker-pool": "workspace:*"
	},
	"devDependencies": {
		"@happy-dom/global-registrator": "^17.4.4",
		"@testing-library/react": "^16.3.0",
		"@types/bun": "^1.2.10",
		"bunup": "^0.4.41",
		"oxlint": "^0.16.6",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"typescript": "^5.8.3"
	},
	"peerDependencies": {
		"react": ">=17.0.0"
	}
}

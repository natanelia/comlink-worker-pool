{
	"name": "comlink-worker-pool-react",
	"version": "0.0.9",
	"description": "Typed React hooks for owning Comlink worker pools and tracking worker task state",
	"author": "Natan Elia",
	"license": "MIT",
	"keywords": [
		"comlink",
		"react",
		"react-hooks",
		"typescript",
		"web-worker",
		"worker-pool"
	],
	"homepage": "https://github.com/natanelia/comlink-worker-pool/tree/main/packages/comlink-worker-pool-react#readme",
	"bugs": {
		"url": "https://github.com/natanelia/comlink-worker-pool/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/natanelia/comlink-worker-pool.git",
		"directory": "packages/comlink-worker-pool-react"
	},
	"engines": {
		"node": ">=18"
	},
	"type": "module",
	"main": "./dist/index.cjs",
	"types": "./dist/index.d.ts",
	"module": "./dist/index.js",
	"files": ["dist"],
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "bunup",
		"test": "bun test",
		"lint": "biome check .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"comlink-worker-pool": "^0.0.9"
	},
	"devDependencies": {
		"@happy-dom/global-registrator": "^17.4.4",
		"@testing-library/react": "^16.3.0",
		"@types/bun": "1.3.13",
		"bunup": "^0.4.41",
		"oxlint": "^0.16.6",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"typescript": "^5.8.3"
	},
	"peerDependencies": {
		"react": ">=17.0.0"
	}
}

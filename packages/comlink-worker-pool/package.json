{
	"name": "comlink-worker-pool",
	"version": "0.1.0",
	"description": "A typed Comlink worker pool with bounded scheduling, observable lifecycle state, and graceful shutdown",
	"author": "Natan Elia",
	"license": "MIT",
	"keywords": [
		"comlink",
		"concurrency",
		"parallelism",
		"typescript",
		"web-worker",
		"worker-pool"
	],
	"homepage": "https://github.com/natanelia/comlink-worker-pool/tree/main/packages/comlink-worker-pool#readme",
	"bugs": {
		"url": "https://github.com/natanelia/comlink-worker-pool/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/natanelia/comlink-worker-pool.git",
		"directory": "packages/comlink-worker-pool"
	},
	"engines": {
		"node": ">=18"
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": ["dist"],
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"sideEffects": false,
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "bunup",
		"test": "bun test",
		"lint": "biome check .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"comlink": "^4.4.2"
	},
	"devDependencies": {
		"@types/bun": "1.3.13",
		"bunup": "^0.4.41",
		"oxlint": "^0.16.6",
		"typescript": "^5.8.3"
	}
}

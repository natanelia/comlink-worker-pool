{
	"name": "comlink-worker-pool",
	"version": "0.0.9",
	"description": "High-performance web worker pool library with TypeScript support, automatic lifecycle management, and parallel task execution",
	"author": "Natan Elia",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/natanelia/comlink-worker-pool.git"
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": ["dist"],
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"sideEffects": false,
	"type": "module",
	"scripts": {
		"build": "bunup",
		"test": "bun test",
		"lint": "biome check .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"comlink": "^4.4.2"
	},
	"devDependencies": {
		"@types/bun": "1.3.13",
		"bunup": "^0.4.41",
		"oxlint": "^0.16.6",
		"typescript": "^5.8.3"
	}
}

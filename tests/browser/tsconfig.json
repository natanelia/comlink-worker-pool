{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"baseUrl": "../..",
		"paths": {
			"comlink-worker-pool": ["packages/comlink-worker-pool/src/index.ts"],
			"comlink-worker-pool-react": [
				"packages/comlink-worker-pool-react/src/index.ts"
			]
		},
		"types": ["@playwright/test", "vite/client"],
